# ── Telegram ──────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=
# URL of the deployed WebApp (e.g. GitHub Pages: https://<user>.github.io/<repo>/?v=N)
WEBAPP_URL=

# Comma-separated Telegram user IDs allowed to run /admin_stats
ADMIN_IDS=
# Chat ID where gate_failed notifications go (group or DM with bot). Optional.
ADMIN_NOTIFICATION_CHAT_ID=

# ── Supabase ──────────────────────────────────────────────
# Public project URL (used by WebApp & bot)
SUPABASE_URL=https://bltbuptzsswaislqagwe.supabase.co
# Service role key — ONLY for bot-side /admin_stats (never expose in WebApp)
SUPABASE_SERVICE_ROLE_KEY=

# ── Edge Function secrets (set via `supabase secrets set ...`) ──
# Set these in the Supabase Dashboard → Project Settings → Edge Functions → Secrets:
#   GEMINI_API_KEY=...
#   GEMINI_MODEL=gemini-2.5-flash-image
#   GEMINI_TIMEOUT_SECONDS=60
